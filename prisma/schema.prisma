// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  initial   String   @unique 
  name      String
  phone     String?  
  role      Role     @default(PIC_LOGISTIK)
  tasks     Ticket[] @relation("PICTasks")
  createdAt DateTime @default(now())
  logs      ActivityLog[]
}

model Ticket {
  id           String    @id @default(uuid())
  ticketNumber String    @unique
  title        String    
  description  String
  category     String    @default("Umum")
  status       Status    @default(OPEN)
  issueImgUrl  String?
  proofImgUrl  String?
  branchName   String
  requesterName String?  // <-- TAMBAHIN BARIS INI BRO
  mediaRequest String?   
  requestDate  DateTime? 
  slaDeadline  DateTime?
  picId        String?
  pic          User?     @relation("PICTasks", fields: [picId], references: [id])
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  logs         ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // Contoh: "COMMENT", "SYSTEM"
  message   String
  createdAt DateTime @default(now())
}

enum Role {
  OPERATOR
  PIC_LOGISTIK
}

enum Status {
  OPEN
  IN_PROGRESS
  DONE
}